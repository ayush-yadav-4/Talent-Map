NEXT_PUBLIC_APP_URL=http://localhost:3000
# Dev: omit NEXT_PUBLIC_API_URL so the browser calls http://localhost:3000/api/v1/... and Next.js proxies to FastAPI.
# Production: set to your API origin only, e.g. https://api.example.com
# NEXT_PUBLIC_API_URL=
#
# Optional — where Next proxies /api/v1/* (default http://127.0.0.1:8000)
# API_PROXY_TARGET=http://127.0.0.1:8000
#
# Optional — server-side fetches only
# INTERNAL_API_URL=http://127.0.0.1:8000
