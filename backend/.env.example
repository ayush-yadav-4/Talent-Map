# App
APP_NAME=Skill Gap Engine
APP_ENV=development
APP_SECRET_KEY=change-me-min-32-characters-long-secret
APP_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# DATABASE_URL — REQUIRED: replace with YOUR real Supabase URI (not this file’s placeholders)
# ---------------------------------------------------------------------------
# Supabase → Project Settings → Database → copy “URI” (Session mode or Direct).
# Replace the password placeholder with your actual database password.
#
# Example (direct, async driver for FastAPI):
#   postgresql+psycopg_async://postgres:ACTUAL_PASSWORD@db.abcdefghijklmnop.supabase.co:5432/postgres
#
# Example (pooler, port 6543 — good for serverless; use Session mode for migrations if needed):
#   postgresql+psycopg_async://postgres.xxxxx:ACTUAL_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Wrong (will NOT work — DNS error):
#   ...@db.YOUR_PROJECT_REF.supabase.co...
#
DATABASE_URL=postgresql+psycopg_async://postgres:REPLACE_WITH_DB_PASSWORD@db.REPLACE_WITH_PROJECT_REF.supabase.co:5432/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0

# JWT (min 32 chars)
JWT_SECRET_KEY=change-me-another-32-char-minimum-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Optional for later features
ANTHROPIC_API_KEY=
RESEND_API_KEY=
MERGE_API_KEY=

SENTRY_DSN=
